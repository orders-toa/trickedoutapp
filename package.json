{
  "name": "toa-companion",
  "version": "1.0.0",
  "author": "Tricked Out Accessories",
  "description": "Tricked Out Accessories - POS Companion App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win --x64",
    "dev": "electron . --dev",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "googleapis": "^140.0.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.trickedoutaccessories.companion",
    "productName": "TOA Companion",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "orders-toa",
        "repo": "trickedoutapp"
      }
    ]
  }
}
